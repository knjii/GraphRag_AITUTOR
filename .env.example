# Paths
PDF_DIR=documents/pdf_docs
MARKDOWN_DIR=documents/markdown_docs
CHROMA_DIR=chroma_db
INGEST_CHECKPOINT_FILE=chroma_db/ingest_checkpoint.json
DEEPEVAL_ARTIFACTS_DIR=deepeval_artifacts

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5vl:3b
OLLAMA_FALLBACK_MODEL=qwen3.5:4b
OLLAMA_EVAL_MODEL=qwen2.5vl:3b
OLLAMA_THINK=auto
# Canonical runtime keys for Ollama:
# OLLAMA_NUM_CTX / OLLAMA_NUM_GPU / OLLAMA_NUM_BATCH / OLLAMA_NUM_PREDICT
# Legacy aliases N_CTX / N_GPU_LAYERS / N_BATCH are supported in settings.py only for backward compatibility.
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=256
OLLAMA_REQUEST_TIMEOUT_SECONDS=0
OLLAMA_EVAL_NUM_PREDICT=256
OLLAMA_EVAL_TEMPERATURE=0.1
OLLAMA_EVAL_THINK=auto
OLLAMA_EVAL_JSON_RETRY_WITHOUT_THINK=0
OLLAMA_EVAL_JSON_RETRY_ATTEMPTS=1
OLLAMA_EVAL_RETRY_NUM_PREDICT_MULTIPLIER=1.5
OLLAMA_EVAL_MAX_NUM_PREDICT=512
OLLAMA_EVAL_STRUCTURED_RECOVERY=1
OLLAMA_EVAL_STRUCTURED_RECOVERY_INPUT_CHARS=6000
OLLAMA_TOP_K=4

# Retrieval / chunking
TOP_K=4
CONVERSATIONAL_RAG_ENABLED=1
CHAT_HISTORY_DIR=chat_history
CHAT_SESSION_ID=default
CHAT_HISTORY_MAX_TURNS=6
RETRIEVER_MODE=hybrid
HYBRID_SPARSE_K=8
HYBRID_DENSE_WEIGHT=0.6
HYBRID_SPARSE_WEIGHT=0.4
HYBRID_RRF_K=60
NEO4J_ENABLED=0
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
GRAPH_RAG_ENABLED=0
GRAPH_WRITE_ENABLED=0
GRAPH_RELATIONS_ENABLED=1
GRAPH_ENTITY_EXTRACTOR=rule
GRAPH_LLM_MODEL=
GRAPH_LLM_TEMPERATURE=0.0
GRAPH_LLM_NUM_PREDICT=384
GRAPH_LLM_INPUT_MAX_CHARS=4000
GRAPH_LLM_MAX_RELATIONS_PER_PASSAGE=20
GRAPH_LLM_PROGRESS_EVERY=25
GRAPH_LLM_FALLBACK_TO_RULE=1
GRAPH_ENTITY_MIN_TOKEN_LEN=3
GRAPH_ENTITY_USE_BIGRAMS=1
GRAPH_ENTITY_MAX_BIGRAMS_PER_PASSAGE=12
GRAPH_ENTITY_MAX_PER_PASSAGE=20
GRAPH_COOCCURS_MAX_PER_PASSAGE=200
GRAPH_COOCCURS_PROVENANCE_LIMIT=20
GRAPH_RETRIEVER_ENABLED=0
GRAPH_RETRIEVER_HOPS=1
GRAPH_RETRIEVER_ENTITY_LIMIT=30
GRAPH_RETRIEVER_PASSAGE_LIMIT=30
GRAPH_RETRIEVER_WEIGHT=0.35
GRAPH_FAIL_ON_ERROR=0
CHUNK_SIZE=1000
CHUNK_OVERLAP=400

# Embeddings
EMBEDDINGS_BACKEND=ollama
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
EMBED_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
EMBED_BATCH_SIZE=32
CHROMA_ADD_BATCH_SIZE=128
EMBED_DEVICE=auto
EMBED_MIN_FREE_VRAM_MB=2048
EMBED_MIN_FREE_VRAM_RATIO=0.7
EMBED_POST_UNLOAD_WAIT_SECONDS=180
EMBED_POST_UNLOAD_POLL_SECONDS=5
EMBED_FORCE_CPU_ON_LOW_VRAM=1
EMBED_PROBE_LLM_BEFORE_INDEX=1
MINERU_MODEL_SOURCE=huggingface
MINERU_TOOLS_CONFIG_JSON=mineru.json
MINERU_LOCAL_PIPELINE_MODELS_DIR=
MINERU_LOCAL_VLM_MODELS_DIR=
MINERU_PARSE_IN_SUBPROCESS=1
MINERU_PARSE_SUBPROCESS_TIMEOUT_SECONDS=0
MINERU_PARSE_STALL_TIMEOUT_SECONDS=300
MINERU_PARSE_HEARTBEAT_INTERVAL_SECONDS=5
MINERU_PARSE_WAIT_POLL_SECONDS=5
MINERU_GPU_RELEASE_WAIT_SECONDS=60
MINERU_GPU_RELEASE_POLL_SECONDS=5
MINERU_GPU_RELEASE_TARGET_FREE_VRAM_MB=3000
MINERU_POST_RELEASE_WAIT_SECONDS=120
MINERU_POST_RELEASE_POLL_SECONDS=5
MINERU_RELEASE_CHECK_ENABLED=1

# Phoenix tracing
PHOENIX_ENDPOINT=http://127.0.0.1:4317
PHOENIX_PROTOCOL=grpc
PHOENIX_PROJECT_NAME=rag_eval

# DeepEval timeout control
RAGAS_TIMEOUT=600
