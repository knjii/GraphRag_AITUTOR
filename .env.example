# Paths
PDF_DIR=documents/pdf_docs
MARKDOWN_DIR=documents/markdown_docs
CHROMA_DIR=chroma_db
INGEST_CHECKPOINT_FILE=chroma_db/ingest_checkpoint.json
DEEPEVAL_ARTIFACTS_DIR=deepeval_artifacts

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5vl:3b
OLLAMA_EVAL_MODEL=qwen2.5vl:3b
OLLAMA_THINK=auto
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=256
OLLAMA_REQUEST_TIMEOUT_SECONDS=0
OLLAMA_EVAL_NUM_PREDICT=256
OLLAMA_EVAL_TEMPERATURE=0.1
OLLAMA_EVAL_THINK=auto
OLLAMA_EVAL_JSON_RETRY_WITHOUT_THINK=0
OLLAMA_EVAL_JSON_RETRY_ATTEMPTS=1
OLLAMA_EVAL_RETRY_NUM_PREDICT_MULTIPLIER=1.5
OLLAMA_EVAL_MAX_NUM_PREDICT=512
OLLAMA_EVAL_STRUCTURED_RECOVERY=1
OLLAMA_EVAL_STRUCTURED_RECOVERY_INPUT_CHARS=6000
OLLAMA_TOP_K=4

# Retrieval / chunking
TOP_K=4
CONVERSATIONAL_RAG_ENABLED=1
CHAT_HISTORY_DIR=chat_history
CHAT_SESSION_ID=default
CHAT_HISTORY_MAX_TURNS=6
RETRIEVER_MODE=hybrid
HYBRID_SPARSE_K=8
HYBRID_DENSE_WEIGHT=0.6
HYBRID_SPARSE_WEIGHT=0.4
HYBRID_RRF_K=60
CHUNK_SIZE=1000
CHUNK_OVERLAP=400

# Embeddings
EMBEDDINGS_BACKEND=ollama
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
EMBED_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
EMBED_BATCH_SIZE=32
CHROMA_ADD_BATCH_SIZE=128
EMBED_DEVICE=auto
EMBED_MIN_FREE_VRAM_MB=2048
EMBED_MIN_FREE_VRAM_RATIO=0.7
EMBED_FORCE_CPU_ON_LOW_VRAM=1
EMBED_PROBE_LLM_BEFORE_INDEX=1

# Phoenix tracing
PHOENIX_ENDPOINT=http://127.0.0.1:4317
PHOENIX_PROTOCOL=grpc
PHOENIX_PROJECT_NAME=rag_eval

# DeepEval timeout control
RAGAS_TIMEOUT=600
